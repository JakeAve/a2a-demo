REGISTRY_PORT=7890
ANTHROPIC_API_KEY=sk-replace-me
CLAUDE_CODE_OAUTH_TOKEN=sk-replace-me
AGENT_BEARER_TOKEN=local-dev-secret
OLLAMA_BASE_URL=http://localhost:11434

# Optional: enable the web UI monitor (see README). Leave unset/commented for
# no events emitted (default). Uncomment to point agents at a running monitor.
# A2A_MONITOR_URL=http://localhost:7891

# Optional: max delegation depth. Unset/0 = pegged to the current agent count
# (min 2), so a bigger swarm can fan out deeper. Set a number to force a fixed
# cap (e.g. 2 for the original REPL→A→B behavior).
# A2A_MAX_DEPTH=0
