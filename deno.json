{
  "tasks": {
    "start": "deno run -A --unstable-kv --env-file=.env src/main.ts",
    "start:agent": "deno run -A --unstable-kv --env-file=.env src/agent-entry.ts",
    "mcp": "deno run -A --unstable-kv --env-file=.env src/mcp.ts",
    "test": "deno test --env-file=.env.example --allow-net --allow-env --allow-read --allow-write --allow-sys --unstable-kv",
    "test:unit": "deno test --env-file=.env.example --allow-net --allow-env --allow-read --allow-write --allow-sys --unstable-kv --ignore=tests/e2e/,tests/repl-e2e.test.ts,tests/rooms/e2e.test.ts",
    "monitor": "deno run --allow-net --allow-env --allow-read --allow-write --unstable-kv --env-file=.env monitor/main.ts",
    "check": "deno fmt --check . && deno lint . && deno check src tests monitor/*.ts scripts",
    "pre-commit": "deno task check && deno task test:unit",
    "pre-push": "deno task check && deno task test",
    "setup": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit .githooks/pre-push"
  },
  "lint": {
    "rules": {
      "exclude": ["require-await"]
    }
  },
  "imports": {
    "@std/dotenv": "jsr:@std/dotenv@^0.225.3",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0",
    "hono": "jsr:@hono/hono@^4.6.0",
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.30.0",
    "@anthropic-ai/claude-agent-sdk": "npm:@anthropic-ai/claude-agent-sdk@^0.3.154",
    "zod": "npm:zod@^4.4.3",
    "@modelcontextprotocol/sdk/": "npm:/@modelcontextprotocol/sdk@^1.18.0/"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "deno.unstable"]
  }
}
